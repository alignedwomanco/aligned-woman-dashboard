{
  "name": "JournalEntry",
  "type": "object",
  "properties": {
    "phase": {
      "type": "string",
      "enum": [
        "Awareness",
        "Liberation",
        "Intention",
        "VisionEmbodiment"
      ]
    },
    "prompt": {
      "type": "string"
    },
    "entry": {
      "type": "string"
    },
    "aiResponse": {
      "type": "string"
    }
  },
  "required": [
    "entry"
  ],
  "rls": {
    "create": {},
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}