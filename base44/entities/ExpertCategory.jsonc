{
  "name": "ExpertCategory",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Category name"
    },
    "color": {
      "type": "string",
      "description": "Hex color for the badge",
      "default": "#7340B9"
    },
    "order": {
      "type": "number",
      "description": "Display order",
      "default": 0
    }
  },
  "required": [
    "name"
  ]
}