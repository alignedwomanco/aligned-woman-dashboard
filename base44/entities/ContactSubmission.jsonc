{
  "name": "ContactSubmission",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "apply_expert",
        "apply_programme",
        "corporate_di",
        "brand_collab",
        "press",
        "general",
        "newsletter"
      ],
      "description": "Type of contact submission"
    },
    "first_name": {
      "type": "string",
      "description": "First name"
    },
    "last_name": {
      "type": "string",
      "description": "Last name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "country": {
      "type": "string",
      "description": "Country"
    },
    "message": {
      "type": "string",
      "description": "Message content"
    },
    "extra_field_label": {
      "type": "string",
      "description": "Label for the extra field"
    },
    "extra_field_value": {
      "type": "string",
      "description": "Value of the extra field"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "reviewed",
        "responded"
      ],
      "default": "new"
    }
  },
  "required": [
    "type",
    "email"
  ]
}