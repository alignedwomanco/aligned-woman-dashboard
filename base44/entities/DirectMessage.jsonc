{
  "name": "DirectMessage",
  "type": "object",
  "properties": {
    "recipientEmail": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "isRead": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "recipientEmail",
    "message"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.recipientEmail": "{{user.email}}"
        }
      ]
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}