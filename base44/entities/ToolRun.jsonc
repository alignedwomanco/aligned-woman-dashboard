{
  "name": "ToolRun",
  "type": "object",
  "properties": {
    "toolSlug": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "InProgress",
        "Complete"
      ],
      "default": "InProgress"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "outputs": {
      "type": "object"
    }
  },
  "required": [
    "toolSlug"
  ]
}